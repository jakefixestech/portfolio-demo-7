---
const title = "Coldbrook Recovery | Heavy Recovery & Towing — White Mountains, NH";
const description = "24-hour heavy recovery and hauling across the White Mountains and North Country. From logging roads to interstate ditches — if you can't drive it out, we can pull it out.";
const siteUrl = "https://coldbrookrecovery.co";
const phone = "(603) 555-0142";
const phoneHref = "tel:+16035550142";

const services = [
  {
    title: "Heavy Recovery",
    description: "Overturned vehicles, semi-trucks, off-road extractions. When standard towing won't cut it, we bring the rotator and get it done.",
    icon: "heavy"
  },
  {
    title: "Light & Medium Towing",
    description: "Cars, vans, pickups, motorcycles. Quick response, careful handling, and we know every shortcut in the North Country.",
    icon: "light"
  },
  {
    title: "Equipment Hauling",
    description: "Skid steers, tractors, excavators, mini-excavators. Secure transport for construction and forestry equipment across New England.",
    icon: "equipment"
  },
  {
    title: "Winch-outs",
    description: "Stuck vehicles, ditch recoveries, snow extractions. We've pulled rigs out of places that don't show up on maps.",
    icon: "winch"
  },
  {
    title: "Long-distance Transport",
    description: "Across NH, VT, ME, MA — secure and insured. From a flatbed run to Boston to heavy haul to Burlington, we move it right.",
    icon: "transport"
  },
  {
    title: "Roadside Assistance",
    description: "Jump-starts, tire changes, fuel delivery, lockouts. The small stuff that strands you — handled fast so you can keep moving.",
    icon: "roadside"
  }
];

const coverage = [
  { area: "Littleton & Bethlehem", time: "20 min avg" },
  { area: "Franconia Notch", time: "35 min avg" },
  { area: "Lincoln & Woodstock", time: "45 min avg" },
  { area: "Berlin & Gorham", time: "50 min avg" },
  { area: "Lancaster & Whitefield", time: "30 min avg" },
  { area: "The Kancamagus", time: "55 min avg" }
];

const equipment = [
  {
    name: "The Workhorse",
    image: "/truck-1.jpg",
    specs: [
      { label: "Model", value: "2021 Peterbilt 567" },
      { label: "Capacity", value: "50-ton rotator" },
      { label: "Role", value: "Heavy recovery" }
    ],
    description: "Our flagship rig. Handles semi-trucks, overturned equipment, and anything too big for a standard wrecker. If it's in a ditch, off an embankment, or blocking the interstate — this is what shows up."
  },
  {
    name: "The Backroader",
    image: "/truck-2.jpg",
    specs: [
      { label: "Model", value: "2019 Ford F-650" },
      { label: "Capacity", value: "16-ton wrecker" },
      { label: "Role", value: "Medium-duty" }
    ],
    description: "Built for the roads the Workhorse can't fit on. Pickups, vans, delivery trucks — and a winch that's pulled more than a few box trucks out of logging roads they never should've been on."
  },
  {
    name: "The Quick Hook",
    image: "/truck-3.jpg",
    specs: [
      { label: "Model", value: "2022 Ford F-550" },
      { label: "Capacity", value: "Flatbed" },
      { label: "Role", value: "Light-duty tow" }
    ],
    description: "Fast response for breakdowns, accidents, and vehicles that need transport rather than recovery. Motorcycles, sedans, and anything that drives onto the bed gets there in one piece."
  }
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={siteUrl} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/og-coldbrook.jpg`} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:type" content="website" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}/og-coldbrook.jpg`} />
  
  <!-- Fonts: Non-blocking preload -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Slab:wght@500;700&display=optional" rel="stylesheet" />
</head>
<body>
  <!-- Skip Link -->
  <a href="#main-content" class="skip-link">Skip to main content</a>
  
  <!-- Sticky Navbar -->
  <header class="navbar" id="navbar">
    <div class="navbar-inner">
      <a href="/" class="logo" aria-label="Coldbrook Recovery Home">
        <span class="logo-main">COLDBROOK</span>
        <span class="logo-sub">RECOVERY CO.</span>
      </a>
      
      <nav class="nav-links" aria-label="Main navigation">
        <a href="#services">Services</a>
        <a href="#coverage">Coverage</a>
        <a href="#equipment">Equipment</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
      
      <div class="nav-actions">
        <span class="phone-display" aria-hidden="true">{phone}</span>
        <a href={phoneHref} class="btn btn-signal" aria-label={`Call 24/7 dispatch at ${phone}`}>24/7 Dispatch</a>
      </div>
      
      <!-- Mobile menu button -->
      <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-nav">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" class="menu-line-top" />
          <line x1="3" y1="12" x2="21" y2="12" class="menu-line-mid" />
          <line x1="3" y1="18" x2="21" y2="18" class="menu-line-bot" />
        </svg>
      </button>
    </div>
    
    <!-- Mobile navigation -->
    <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
      <a href="#services">Services</a>
      <a href="#coverage">Coverage</a>
      <a href="#equipment">Equipment</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
      <a href={phoneHref} class="btn btn-signal mobile-dispatch">Call Dispatch — {phone}</a>
    </nav>
  </header>
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-video-container">
        <video
          class="hero-video"
          autoplay
          muted
          loop
          playsinline
          poster="/hero-poster.webp"
          aria-hidden="true"
        >
          <source src="/hero-coldbrook.mp4" type="video/mp4" />
        </video>
        <img src="/hero-poster.webp" alt="" class="hero-poster-fallback" aria-hidden="true" />
      </div>
      <div class="hero-overlay"></div>
      
      <div class="hero-content">
        <p class="eyebrow">HEAVY RECOVERY • TOWING • TRANSPORT</p>
        <h1>We work where the roads end.</h1>
        <p class="hero-sub">24-hour heavy recovery and hauling across the White Mountains and North Country. From logging roads to interstate ditches — if you can&apos;t drive it out, we can pull it out.</p>
        <div class="hero-ctas">
          <a href={phoneHref} class="btn btn-signal btn-lg">Call Dispatch — {phone}</a>
          <a href="#services" class="btn btn-outline">Our Services</a>
        </div>
      </div>
    </section>
    
    <!-- Topo Strip -->
    <div class="topo-strip">
      <svg class="topo-bg" viewBox="0 0 1200 80" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,40 Q100,20 200,40 T400,35 T600,45 T800,38 T1000,42 T1200,40" fill="none" stroke="currentColor" stroke-width="0.5"/>
        <path d="M0,50 Q150,30 300,50 T600,45 T900,55 T1200,48" fill="none" stroke="currentColor" stroke-width="0.5"/>
        <path d="M0,30 Q200,50 400,30 T800,35 T1200,32" fill="none" stroke="currentColor" stroke-width="0.5"/>
        <path d="M0,60 Q100,40 200,60 T400,55 T600,65 T800,58 T1000,62 T1200,58" fill="none" stroke="currentColor" stroke-width="0.5"/>
        <path d="M0,20 Q150,40 300,20 T600,25 T900,18 T1200,22" fill="none" stroke="currentColor" stroke-width="0.5"/>
      </svg>
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-number">24/7</span>
          <span class="stat-label">Dispatch Available</span>
        </div>
        <div class="stat">
          <span class="stat-number">850 mi²</span>
          <span class="stat-label">Service Area</span>
        </div>
        <div class="stat">
          <span class="stat-number">20 Tons</span>
          <span class="stat-label">Max Recovery Capacity</span>
        </div>
        <div class="stat">
          <span class="stat-number">Est. 2014</span>
          <span class="stat-label">North Country Owned</span>
        </div>
      </div>
    </div>
    
    <!-- Services Section -->
    <section id="services" class="section">
      <div class="container">
        <p class="eyebrow">CAPABILITIES</p>
        <h2>What We Pull</h2>
        
        <div class="services-grid">
          {services.map((service) => (
            <article class="service-card">
              <div class="service-icon">
                {service.icon === "heavy" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="4" y="24" width="28" height="14" rx="2" />
                    <rect x="32" y="28" width="12" height="10" rx="1" />
                    <circle cx="12" cy="42" r="4" />
                    <circle cx="24" cy="42" r="4" />
                    <circle cx="40" cy="42" r="4" />
                    <path d="M18 24V12L26 8V24" />
                    <path d="M26 12H34L38 18V28" />
                    <path d="M14 16H22" />
                  </svg>
                )}
                {service.icon === "light" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="6" y="20" width="24" height="12" rx="2" />
                    <rect x="30" y="24" width="12" height="8" rx="1" />
                    <circle cx="14" cy="36" r="4" />
                    <circle cx="38" cy="36" r="4" />
                    <path d="M6 20L10 12H26L30 20" />
                    <line x1="14" y1="12" x2="14" y2="20" />
                    <line x1="22" y1="12" x2="22" y2="20" />
                  </svg>
                )}
                {service.icon === "equipment" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="8" y="28" width="32" height="8" rx="1" />
                    <circle cx="14" cy="40" r="4" />
                    <circle cx="34" cy="40" r="4" />
                    <path d="M12 28V16H20V28" />
                    <path d="M20 20H36V28" />
                    <path d="M36 20L42 14" />
                    <path d="M40 10L44 14L42 16" />
                  </svg>
                )}
                {service.icon === "winch" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="24" cy="24" r="8" />
                    <circle cx="24" cy="24" r="3" />
                    <path d="M24 16V8" />
                    <path d="M24 40V32" />
                    <path d="M32 24H44" />
                    <path d="M4 24H16" />
                    <path d="M8 20L4 24L8 28" />
                    <path d="M44 24L40 20M44 24L40 28" />
                  </svg>
                )}
                {service.icon === "transport" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="4" y="22" width="28" height="12" rx="1" />
                    <rect x="32" y="26" width="12" height="8" rx="1" />
                    <circle cx="12" cy="38" r="4" />
                    <circle cx="24" cy="38" r="4" />
                    <circle cx="40" cy="38" r="4" />
                    <path d="M4 22L4 18L32 18L32 22" />
                    <path d="M10 18V14H26V18" />
                    <path d="M44 14L40 8H36L32 14" />
                  </svg>
                )}
                {service.icon === "roadside" && (
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="14" y="8" width="20" height="32" rx="2" />
                    <path d="M20 16H28" />
                    <path d="M20 22H28" />
                    <circle cx="24" cy="32" r="4" />
                    <path d="M4 24L14 20V28L4 24Z" />
                    <path d="M44 24L34 20V28L44 24Z" />
                    <path d="M24 4V8" />
                  </svg>
                )}
              </div>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Coverage Section -->
    <section id="coverage" class="section section-alt">
      <div class="container">
        <p class="eyebrow">COVERAGE AREA</p>
        <h2>Where We Run</h2>
        
        <div class="coverage-grid">
          <div class="coverage-map">
            <svg viewBox="0 0 400 500" fill="none" aria-label="Stylized topographic map of northern New Hampshire showing Coldbrook Recovery coverage area">
              <title>Coverage Map of Northern New Hampshire</title>
              <!-- Background -->
              <rect width="400" height="500" fill="#2C3E2D" />
              
              <!-- Topo lines - mountain ranges -->
              <g stroke="#F2EBDC" stroke-width="0.5" opacity="0.3">
                <!-- Franconia Range -->
                <path d="M80,280 Q100,260 120,280 Q140,260 160,280 Q180,260 200,280" />
                <path d="M85,290 Q105,270 125,290 Q145,270 165,290 Q185,270 205,290" />
                <path d="M90,300 Q110,280 130,300 Q150,280 170,300 Q190,280 210,300" />
                
                <!-- Presidential Range -->
                <path d="M250,200 Q280,160 310,200 Q340,160 370,200" />
                <path d="M255,215 Q285,175 315,215 Q345,175 375,215" />
                <path d="M260,230 Q290,190 320,230 Q350,190 380,230" />
                <path d="M265,245 Q295,205 325,245 Q355,205 385,245" />
                
                <!-- Northern mountains -->
                <path d="M150,80 Q180,50 210,80 Q240,50 270,80" />
                <path d="M155,95 Q185,65 215,95 Q245,65 275,95" />
                <path d="M160,110 Q190,80 220,110 Q250,80 280,110" />
                
                <!-- Kancamagus area -->
                <path d="M150,380 Q200,340 250,380 Q300,340 350,380" />
                <path d="M155,395 Q205,355 255,395 Q305,355 355,395" />
                <path d="M160,410 Q210,370 260,410 Q310,370 360,410" />
              </g>
              
              <!-- Roads - dashed -->
              <g stroke="#F2EBDC" stroke-width="1.5" stroke-dasharray="8,4" opacity="0.5">
                <!-- I-93 -->
                <path d="M140,450 L140,350 L120,280 L120,180 L140,100 L160,30" />
                <!-- Route 3 -->
                <path d="M180,30 L200,100 L220,200 L200,300 L180,400 L160,450" />
                <!-- Route 2 -->
                <path d="M30,200 L100,190 L200,180 L300,170 L380,160" />
                <!-- Kancamagus -->
                <path d="M120,380 L200,360 L280,370 L350,390" />
                <!-- Route 302 -->
                <path d="M30,280 L100,290 L180,300 L260,280" />
              </g>
              
              <!-- Location markers -->
              <g fill="#F2EBDC">
                <!-- Littleton (HQ) -->
                <circle cx="140" cy="180" r="6" fill="#E8541A" />
                <circle cx="140" cy="180" r="10" fill="none" stroke="#E8541A" stroke-width="2" />
                <text x="155" y="175" font-size="12" font-weight="600" fill="#F2EBDC">LITTLETON</text>
                <text x="155" y="188" font-size="9" fill="#9A9384">HQ</text>
                
                <!-- Lincoln -->
                <circle cx="140" cy="340" r="4" />
                <text x="152" y="344" font-size="11" fill="#F2EBDC">Lincoln</text>
                
                <!-- Berlin -->
                <circle cx="300" cy="120" r="4" />
                <text x="312" y="124" font-size="11" fill="#F2EBDC">Berlin</text>
                
                <!-- Lancaster -->
                <circle cx="180" cy="130" r="4" />
                <text x="192" y="134" font-size="11" fill="#F2EBDC">Lancaster</text>
                
                <!-- Whitefield -->
                <circle cx="160" cy="160" r="4" />
                <text x="115" y="155" font-size="11" fill="#F2EBDC">Whitefield</text>
                
                <!-- Franconia Notch -->
                <circle cx="130" cy="280" r="4" />
                <text x="70" y="265" font-size="10" fill="#F2EBDC">Franconia</text>
                <text x="80" y="276" font-size="10" fill="#F2EBDC">Notch</text>
                
                <!-- The Kanc -->
                <text x="200" y="385" font-size="10" font-style="italic" fill="#9A9384">The Kancamagus</text>
              </g>
              
              <!-- Legend -->
              <g transform="translate(20, 430)">
                <circle cx="8" cy="8" r="5" fill="#E8541A" />
                <text x="20" y="12" font-size="10" fill="#9A9384">Coldbrook HQ</text>
                <line x1="0" y1="28" x2="20" y2="28" stroke="#F2EBDC" stroke-width="1.5" stroke-dasharray="4,2" opacity="0.5" />
                <text x="28" y="32" font-size="10" fill="#9A9384">Major Routes</text>
              </g>
            </svg>
          </div>
          
          <div class="coverage-list">
            <ul class="coverage-areas">
              {coverage.map((item) => (
                <li>
                  <span class="coverage-area">{item.area}</span>
                  <span class="coverage-time">{item.time}</span>
                </li>
              ))}
            </ul>
            <p class="coverage-note">Outside our standard area? Call dispatch — we go where we&apos;re needed.</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Equipment Section -->
    <section id="equipment" class="section">
      <div class="container">
        <p class="eyebrow">BUILT FOR BAD ROADS</p>
        <h2>The Fleet</h2>
        
        <div class="equipment-grid">
          {equipment.map((truck) => (
            <article class="equipment-card">
              <div class="equipment-image">
                <img src={truck.image} alt={`${truck.name} - ${truck.specs[0].value}`} loading="lazy" />
              </div>
              <div class="equipment-content">
                <h3>{truck.name}</h3>
                <dl class="equipment-specs">
                  {truck.specs.map((spec) => (
                    <div class="spec-row">
                      <dt>{spec.label}</dt>
                      <dd>{spec.value}</dd>
                    </div>
                  ))}
                </dl>
                <p>{truck.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
    
    <!-- About Section -->
    <section id="about" class="section section-alt">
      <div class="container">
        <div class="about-grid">
          <div class="about-image">
            <img src="/owners.jpg" alt="The owners of Coldbrook Recovery" loading="lazy" />
          </div>
          <div class="about-content">
            <p class="eyebrow">OUR STORY</p>
            <h2>Built by people who know the terrain</h2>
            <p>Coldbrook Recovery started the way a lot of North Country businesses do: out of necessity. The owners spent years in volunteer fire and emergency dispatch, watching tow companies from an hour south struggle with our roads, our weather, and our distances. Too many cold nights waiting on a flatbed that didn&apos;t know a Class VI road from a driveway.</p>
            <p>In 2014, they bought a used wrecker and started taking calls. Word spread. Now we run three trucks, cover 850 square miles, and dispatch around the clock. We know which bridges have weight limits, which logging roads are passable in mud season, and which hills will ice over before the rest of the county.</p>
            <p>This isn&apos;t a franchise. There&apos;s no call center. When you call Coldbrook, you&apos;re talking to someone who&apos;s driven these roads in every season — and who&apos;ll have a truck to you as fast as the terrain allows.</p>
            <blockquote>
              <p>&ldquo;We don&apos;t just know the White Mountains. We live them, work them, and keep them moving.&rdquo;</p>
              <cite>— Coldbrook Recovery, Founders</cite>
            </blockquote>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Contact Section -->
    <section id="contact" class="section">
      <div class="container">
        <p class="eyebrow">GET IN TOUCH</p>
        <h2>Need a Truck?</h2>
        
        <div class="contact-grid">
          <div class="contact-dispatch">
            <a href={phoneHref} class="btn btn-signal btn-dispatch">
              <span class="dispatch-label">CALL DISPATCH</span>
              <span class="dispatch-phone">{phone}</span>
            </a>
            <ul class="dispatch-info">
              <li>Available 24/7/365</li>
              <li>Heavy Recovery Hotline</li>
              <li>Same-day service when available</li>
            </ul>
          </div>
          
          <form class="contact-form" action="#" method="POST">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="phone-input">Phone</label>
              <input type="tel" id="phone-input" name="phone" required autocomplete="tel" />
            </div>
            <div class="form-group">
              <label for="vehicle">Vehicle Type / Equipment</label>
              <input type="text" id="vehicle" name="vehicle" placeholder="e.g., 2019 Ford F-150, Excavator" />
            </div>
            <div class="form-group">
              <label for="location">Location</label>
              <input type="text" id="location" name="location" placeholder="Address or nearest landmark" />
            </div>
            <div class="form-group">
              <label for="notes">Notes</label>
              <textarea id="notes" name="notes" rows="3" placeholder="Describe the situation"></textarea>
            </div>
            <button type="submit" class="btn btn-cream">Send Message</button>
          </form>
        </div>
        
        <div class="contact-info-row">
          <div class="contact-info-item">
            <span class="contact-info-label">Address</span>
            <address>87 Mill Brook Rd<br />Littleton, NH 03561</address>
          </div>
          <div class="contact-info-item">
            <span class="contact-info-label">Email</span>
            <a href="mailto:dispatch@coldbrookrecovery.co">dispatch@coldbrookrecovery.co</a>
          </div>
          <div class="contact-info-item">
            <span class="contact-info-label">Hours</span>
            <dl class="hours-list">
              <div><dt>Dispatch</dt><dd>24/7</dd></div>
              <div><dt>Office</dt><dd>M–F 7am–6pm</dd></div>
            </dl>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="logo">
            <span class="logo-main">COLDBROOK</span>
            <span class="logo-sub">RECOVERY CO.</span>
          </div>
          <p class="footer-tagline">North Country Heavy Recovery & Hauling — Littleton, NH</p>
        </div>
        
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="#services">Services</a>
          <span class="footer-sep" aria-hidden="true">|</span>
          <a href="#coverage">Coverage</a>
          <span class="footer-sep" aria-hidden="true">|</span>
          <a href="#equipment">Equipment</a>
          <span class="footer-sep" aria-hidden="true">|</span>
          <a href="#about">About</a>
          <span class="footer-sep" aria-hidden="true">|</span>
          <a href="#contact">Contact</a>
        </nav>
        
        <div class="footer-dispatch">
