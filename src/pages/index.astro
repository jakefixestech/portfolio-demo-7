            <a href="https://google.com/maps" aria-label="Google Maps" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C7.31 0 3.5 3.81 3.5 8.5c0 5.94 7.19 14.66 7.5 15.03.27.32.73.32 1 0 .31-.37 7.5-9.09 7.5-15.03C19.5 3.81 15.69 0 12 0zm0 12.5c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4z"/>
