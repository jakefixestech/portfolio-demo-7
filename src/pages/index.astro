<script>
// @ts-nocheck

// Mobile menu toggle (defined first since scroll handler references these)
const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
const mobileNav = document.getElementById('mobile-nav');

if (mobileMenuBtn && mobileNav) {
  mobileMenuBtn.addEventListener('click', () => {
    const isOpen = mobileNav.classList.toggle('open');
    mobileMenuBtn.setAttribute('aria-expanded', String(isOpen));
  });
  
  // Close mobile menu when clicking a link
  mobileNav.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
    });
  });
}

// Sticky navbar — hide on scroll down, show on scroll up
// Improves accessibility for users zoomed to 400%+ (WCAG 1.4.10)
const navbar = document.getElementById('navbar');
let lastScrollY = window.scrollY;
let ticking = false;
const SCROLL_THRESHOLD = 5; // ignore micro-scrolls

function handleScroll() {
  const currentScrollY = window.scrollY;
  const scrollDelta = currentScrollY - lastScrollY;
  
  // Solidify navbar background after scrolling past hero
  if (currentScrollY > 100) {
    navbar.classList.add('scrolled');
  } else {
    navbar.classList.remove('scrolled');
  }
  
  // Always show navbar at top of page
  if (currentScrollY < 100) {
    navbar.classList.remove('nav-hidden');
    lastScrollY = currentScrollY;
    ticking = false;
    return;
  }
  
  // Ignore micro-scrolls
  if (Math.abs(scrollDelta) < SCROLL_THRESHOLD) {
    ticking = false;
    return;
  }
  
  if (scrollDelta > 0) {
    // Scrolling down — hide navbar
    navbar.classList.add('nav-hidden');
    // Also close mobile menu if it's open
    if (mobileNav) mobileNav.classList.remove('open');
    if (mobileMenuBtn) mobileMenuBtn.setAttribute('aria-expanded', 'false');
  } else {
    // Scrolling up — show navbar
    navbar.classList.remove('nav-hidden');
  }
  
  lastScrollY = currentScrollY;
  ticking = false;
}

window.addEventListener('scroll', () => {
  if (!ticking) {
    window.requestAnimationFrame(handleScroll);
    ticking = true;
  }
}, { passive: true });

// Respect reduced motion for video
const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
const heroVideo = document.querySelector('.hero-video');

function handleReducedMotion() {
  if (heroVideo) {
    if (prefersReducedMotion.matches) {
      heroVideo.pause();
    } else {
      heroVideo.play().catch(() => {
        // Autoplay was prevented, that's okay
      });
    }
  }
}

prefersReducedMotion.addEventListener('change', handleReducedMotion);
handleReducedMotion();
</script>