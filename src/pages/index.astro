</html>

<style>
  /* ===== CSS Custom Properties ===== */
  :root {
    /* Colors */
    --color-background: #0F1410;
    --color-surface: #1A2018;
    --color-forest: #2C3E2D;
    --color-cream: #F2EBDC;
    --color-muted: #9A9384;
    --color-signal: #E8541A;
    
    /* Typography */
    --font-display: 'Roboto Slab', Georgia, serif;
    --font-body: 'Inter', system-ui, sans-serif;
    
    /* Spacing */
    --space-xs: 0.5rem;
    --space-sm: 1rem;
    --space-md: 1.5rem;
    --space-lg: 2rem;
    --space-xl: 3rem;
    --space-2xl: 4rem;
    --space-3xl: 6rem;
    
    /* Layout */
    --container-max: 1280px;
    --navbar-height: 80px;
    
    /* Transitions */
    --transition-fast: 0.15s ease;
    --transition-base: 0.3s ease;
  }
  
  /* ===== Reset & Base ===== */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--navbar-height);
  }
  
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
    
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
  
  body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-cream);
    background-color: var(--color-background);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  img,
  video {
    max-width: 100%;
    height: auto;
    display: block;
  }
  
  a {
    color: inherit;
    text-decoration: none;
  }
  
  button {
    font: inherit;
    cursor: pointer;
    border: none;
    background: none;
  }
  
  /* Focus states */
  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  textarea:focus-visible {
    outline: 2px solid var(--color-signal);
    outline-offset: 2px;
  }
  
  /* ===== Skip Link ===== */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-sm);
    z-index: 9999;
    padding: var(--space-sm) var(--space-md);
    background-color: var(--color-signal);
    color: var(--color-background);
    font-weight: 700;
    border-radius: 4px;
  }
  
  .skip-link:focus {
    top: var(--space-sm);
  }
  
  /* ===== Typography ===== */
  h1, h2, h3, h4 {
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  
  h1 {
    font-size: clamp(3.5rem, 10vw, 7rem);
  }
  
  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-lg);
  }
  
  h3 {
    font-size: 1.25rem;
    font-weight: 500;
  }
  
  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }
  
  /* ===== Layout ===== */
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }
  
  .section {
    padding: var(--space-3xl) 0;
    scroll-margin-top: var(--navbar-height);
  }
  
  .section-alt {
    background-color: var(--color-surface);
  }
  
  /* ===== Buttons ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: 0.875rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    text-align: center;
    border-radius: 4px;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }
  
  /* Signal-orange button uses dark text for AA contrast (like real safety signs) */
  .btn-signal {
    background-color: var(--color-signal);
    color: var(--color-background);
  }
  
  .btn-signal:hover {
    background-color: #ff6a30;
    color: var(--color-background);
  }
  
  .btn-outline {
    border: 2px solid var(--color-cream);
    color: var(--color-cream);
    background: transparent;
  }
  
  .btn-outline:hover {
    background-color: var(--color-cream);
    color: var(--color-background);
  }
  
  .btn-cream {
    background-color: var(--color-cream);
    color: var(--color-background);
  }
  
  .btn-cream:hover {
    background-color: #e5ddd0;
  }
  
  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.0625rem;
  }
  
  /* ===== Navbar ===== */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background-color: rgba(15, 20, 16, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: background-color var(--transition-base), transform var(--transition-base);
  }
  
  .navbar.scrolled {
    background-color: rgba(15, 20, 16, 0.95);
  }
  
  /* Hide navbar when scrolling down — gives zoomed users (WCAG 1.4.10)
     and small viewports more room to read content */
  .navbar.nav-hidden {
    transform: translateY(-100%);
  }
  
  @media (prefers-reduced-motion: reduce) {
    .navbar {
      transition: none;
    }
    .navbar.nav-hidden {
      transform: none;
    }
  }
  
  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--navbar-height);
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }
  
  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  
  .logo-main {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  
  .logo-sub {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  
  .nav-links {
    display: none;
    gap: var(--space-lg);
  }
  
  .nav-links a {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-cream);
    transition: color var(--transition-fast);
  }
  
  .nav-links a:hover {
    color: var(--color-signal);
  }
  
  .nav-actions {
    display: none;
    align-items: center;
    gap: var(--space-md);
  }
  
  /* Phone display is now decorative text — the dispatch button beside it
     handles the actual tel: link, eliminating WAVE redundant-link alerts */
  .phone-display {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    color: var(--color-cream);
  }
  
  .mobile-menu-btn {
    display: flex;
    padding: var(--space-xs);
    color: var(--color-cream);
  }
  
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: var(--space-md);
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-forest);
  }
  
  .mobile-nav.open {
    display: flex;
  }
  
  .mobile-nav a {
    padding: var(--space-sm) 0;
    font-weight: 500;
    border-bottom: 1px solid var(--color-forest);
  }
  
  .mobile-nav .mobile-dispatch {
    margin-top: var(--space-md);
    text-align: center;
    border-bottom: none;
  }
  
  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
    
    .nav-actions {
      display: flex;
    }
    
    .mobile-menu-btn {
      display: none;
    }
  }
  
  /* ===== Hero ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  
  .hero-video-container {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  
  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .hero-poster-fallback {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none;
    }
    
    .hero-poster-fallback {
      display: block;
    }
  }
  
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to bottom,
      rgba(15, 20, 16, 0.4) 0%,
      rgba(15, 20, 16, 0.85) 100%
    );
  }
  
  .hero-content {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-md);
    padding-bottom: var(--space-2xl);
  }
  
  .hero h1 {
    margin-bottom: var(--space-md);
  }
  
  .hero-sub {
    max-width: 55ch;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-cream);
    opacity: 0.9;
    margin-bottom: var(--space-lg);
  }
  
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  
  /* ===== Topo Strip ===== */
  .topo-strip {
    position: relative;
    padding: var(--space-xl) 0;
    background-color: var(--color-surface);
    overflow: hidden;
  }
  
  .topo-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-forest);
    opacity: 0.4;
  }
  
  .stats-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }
  
  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .stat {
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-cream);
    margin-bottom: var(--space-xs);
  }
  
  .stat-label {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  
  /* ===== Services ===== */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
  
  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .service-card {
    padding: var(--space-lg);
    background-color: var(--color-surface);
    border: 1px solid var(--color-forest);
    border-radius: 8px;
    transition: all var(--transition-base);
  }
  
  .service-card:hover {
    border-color: var(--color-signal);
  }
  
  .service-card:hover .service-icon {
    color: var(--color-signal);
  }
  
  .service-icon {
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-md);
    color: var(--color-cream);
    transition: color var(--transition-base);
  }
  
  .service-icon svg {
    width: 100%;
    height: 100%;
  }
  
  .service-card h3 {
    margin-bottom: var(--space-sm);
  }
  
  .service-card p {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  
  /* ===== Coverage ===== */
  .coverage-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }
  
  @media (min-width: 768px) {
    .coverage-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }
  
  .coverage-map {
    border-radius: 8px;
    overflow: hidden;
  }
  
  .coverage-map svg {
    width: 100%;
    height: auto;
    font-family: var(--font-body);
  }
  
  .coverage-areas {
    list-style: none;
  }
  
  .coverage-areas li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-forest);
  }
  
  .coverage-area {
    font-weight: 500;
  }
  
  .coverage-time {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }
  
  .coverage-note {
    margin-top: var(--space-lg);
    padding: var(--space-md);
    background-color: var(--color-background);
    border-left: 3px solid var(--color-signal);
    font-size: 0.9375rem;
    color: var(--color-cream);
  }
  
  /* ===== Equipment ===== */
  .equipment-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  
  @media (min-width: 768px) {
    .equipment-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .equipment-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-forest);
    border-radius: 8px;
    overflow: hidden;
  }
  
  .equipment-image {
    aspect-ratio: 4 / 3;
    background-color: var(--color-forest);
  }
  
  .equipment-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .equipment-content {
    padding: var(--space-md);
  }
  
  .equipment-content h3 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    margin-bottom: var(--space-sm);
  }
  
  .equipment-specs {
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-forest);
  }
  
  .spec-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    padding: 0.25rem 0;
  }
  
  .spec-row dt {
    color: var(--color-muted);
  }
  
  .spec-row dd {
    font-weight: 500;
  }
  
  .equipment-content > p {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
  
  /* ===== About ===== */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }
  
  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr 1.5fr;
      align-items: start;
    }
  }
  
  .about-image {
    aspect-ratio: 3 / 4;
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--color-forest);
  }
  
  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .about-content p {
    margin-bottom: var(--space-md);
    color: var(--color-cream);
    opacity: 0.9;
  }
  
  .about-content blockquote {
    margin-top: var(--space-xl);
    padding-left: var(--space-lg);
    border-left: 3px solid var(--color-signal);
  }
  
  .about-content blockquote p {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    font-style: italic;
    color: var(--color-cream);
    margin-bottom: var(--space-sm);
  }
  
  .about-content cite {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: normal;
  }
  
  /* ===== Contact ===== */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }
  
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  
  .contact-dispatch {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  
  .btn-dispatch {
    flex-direction: column;
    padding: var(--space-lg) var(--space-2xl);
    width: 100%;
    max-width: 320px;
  }
  
  .dispatch-label {
    font-size: 0.8125rem;
    letter-spacing: 0.15em;
  }
  
  .dispatch-phone {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
  
  .dispatch-info {
    list-style: none;
    margin-top: var(--space-md);
  }
  
  .dispatch-info li {
    font-size: 0.9375rem;
    color: var(--color-muted);
    padding: var(--space-xs) 0;
  }
  
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  
  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  
  .form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-cream);
  }
  
  .form-group input,
  .form-group textarea {
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-cream);
    background-color: var(--color-background);
    border: 1px solid var(--color-forest);
    border-radius: 4px;
    transition: border-color var(--transition-fast);
